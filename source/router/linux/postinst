#!/bin/sh
set -e

# Register the service via the application itself (account and sandboxing are provisioned there,
# shared with the command line). --install is a no-op when no configuration exists yet, so a clean
# install does not fail; on an upgrade it refreshes an already-configured service.
if [ "$1" = "configure" ]; then
    /usr/bin/aspia_router --install
fi
