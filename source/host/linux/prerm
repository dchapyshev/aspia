#!/bin/sh
set -e

# Stop and disable the service while the package files are still on disk.
if [ "$1" = "remove" ] && [ -d /run/systemd/system ]; then
    systemctl disable --now aspia-host-service.service >/dev/null 2>&1 || true
fi

# Remove the PAM policy installed by postinst (it is not part of the package file list).
if [ "$1" = "remove" ]; then
    rm -f /etc/pam.d/aspia-terminal
fi
