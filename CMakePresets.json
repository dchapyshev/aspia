{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/builds/${presetName}",
      "generator": "Ninja Multi-Config",
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/vcpkg4aspia",
        "VCPKG_BINARY_SOURCES": "default,readwrite",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/builds/${presetName}/vcpkg_installed"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_WARN_DEPRECATED": "OFF",
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "${sourceDir}/vcpkg4aspia/scripts/buildsystems/vcpkg.cmake"
        },
        "VCPKG_TARGET_TRIPLET": {
          "type": "STRING",
          "value": "$env{VCPKG_TRIPLET}"
        },
        "VCPKG_HOST_TRIPLET": {
          "type": "STRING",
          "value": "$env{VCPKG_TRIPLET}"
        }
      }
    },
    {
      "name": "ci",
      "inherits": [
        "base"
      ]
    },
    {
      "name": "local-linux-x64",
      "inherits": [
        "base"
      ],
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      },
      "environment": {
        "VCPKG_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "local-linux-arm64",
      "inherits": [
        "base"
      ],
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux"
      },
      "environment": {
        "VCPKG_TRIPLET": "arm64-linux"
      }
    },
    {
      "name": "local-mac-arm64",
      "inherits": [
        "base"
      ],
      "architecture": {
        "value": "arm64",
        "strategy": "external"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [
            "macOS"
          ]
        }
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "CMAKE_PROGRAM_PATH": "/opt/homebrew/bin"
      },
      "environment": {
        "VCPKG_TRIPLET": "arm64-osx"
      }
    },
    {
      "name": "local-mac-x64",
      "inherits": [
        "base"
      ],
      "architecture": {
        "value": "x86_64",
        "strategy": "external"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [
            "macOS"
          ]
        }
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-osx",
        "CMAKE_PROGRAM_PATH": "/opt/homebrew/bin"
      },
      "environment": {
        "VCPKG_TRIPLET": "x64-osx"
      }
    },
    {
      "name": "local-win-base",
      "hidden": true,
      "inherits": [
        "base"
      ],
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [
            "Windows"
          ]
        }
      }
    },
    {
      "name": "local-win-x86",
      "inherits": [
        "local-win-base"
      ],
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-windows-static"
      },
      "environment": {
        "VCPKG_TRIPLET": "x86-windows-static",
        "VCPKG_DEFAULT_HOST_TRIPLET": "x86-windows-static"
      }
    },
    {
      "name": "local-win-arm64",
      "inherits": [
        "local-win-base"
      ],
      "architecture": {
        "value": "arm64",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-windows-static"
      },
      "environment": {
        "VCPKG_TRIPLET": "arm64-windows-static",
        "VCPKG_DEFAULT_HOST_TRIPLET": "arm64-windows-static"
      }
    },
    {
      "name": "local-win-x64",
      "inherits": [
        "local-win-base"
      ],
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      },
      "environment": {
        "VCPKG_TRIPLET": "x64-windows-static",
        "VCPKG_DEFAULT_HOST_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "android-base",
      "hidden": true,
      "inherits": [
        "base"
      ],
      "generator": "Ninja",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "VCPKG_HOST_TRIPLET": "x64-windows-static",
        "QT_USE_VCPKG": "OFF"
      },
      "environment": {
        "VCPKG_TRIPLET": "arm64-android",
        "VCPKG_DEFAULT_HOST_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "ci-android-base",
      "hidden": true,
      "inherits": [
        "android-base"
      ],
      "cacheVariables": {
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "$penv{QT_ANDROID_PATH}/lib/cmake/Qt6/qt.toolchain.cmake"
        },
        "QT_HOST_PATH": "$penv{QT_HOST_PATH}",
        "ANDROID_SDK_ROOT": "$penv{ANDROID_SDK_ROOT}",
        "ANDROID_NDK_ROOT": "$penv{ANDROID_NDK_ROOT}"
      }
    },
    {
      "name": "ci-android-release",
      "inherits": [
        "ci-android-base"
      ]
    },
    {
      "name": "ci-android-debug",
      "inherits": [
        "ci-android-base"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ci-release",
      "configurePreset": "ci",
      "configuration": "Release"
    },
    {
      "name": "ci-debug",
      "configurePreset": "ci",
      "configuration": "Debug"
    },
    {
      "name": "ci-android-apk-release",
      "configurePreset": "ci-android-release",
      "targets": [
        "apk"
      ]
    },
    {
      "name": "ci-android-apk-debug",
      "configurePreset": "ci-android-debug",
      "targets": [
        "apk"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "ci-release", 
      "configurePreset": "ci",
      "configuration": "Release"
    },
    {
      "name": "ci-debug", 
      "configurePreset": "ci",
      "configuration": "Debug"
    }
  ]
}
